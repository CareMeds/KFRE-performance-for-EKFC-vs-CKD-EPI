# baseline characteristics stratified by different GFR estimates
## Create a variable to stratify on
create_gfr_strata <- function(data, var_name) {
  var <- sym(var_name) # Convert string to symbol
  strat_var <- paste0(var_name, "_strat")

  data %>%
    mutate(
      !!strat_var := case_when(
        !!var < 30 ~ "<30 ml/min/1.72m²",
        !!var >= 30 & !!var < 60 ~ "30-59 ml/min/1.72m²",
        !!var >= 60 & !!var < 90 ~ "60-89 ml/min/1.72m²",
        !!var >= 90 ~ "≥90 ml/min/1.72m²"
      )
    ) %>%
    mutate(
      !!strat_var := factor(
        !!sym(strat_var),
        levels = c(
          "<30 ml/min/1.72m²",
          "30-59 ml/min/1.72m²",
          "60-89 ml/min/1.72m²",
          "≥90 ml/min/1.72m²"
        )
      )
    )
}

data |>
  create_gfr_strata("ckd_epi_2021_cr") |>
  relocate(ckd_epi_2021_cr_strat)


