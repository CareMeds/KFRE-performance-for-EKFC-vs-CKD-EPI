#---------------------- Prepare settings for ggsave ----------------------------

save_for_manuscript <- function(filename_wo_extension, plot, height = 164*1.5, width = 164) {

   filnename <- glue::glue("{filename_wo_extension}.jpeg")

   ggsave(filnename, plot = plot,
          device =  ragg::agg_jpeg,
          path = here::here("output", "manuscript"),
          unit = "mm",
          dpi = 300,
          height = height, width = width)

}

#---------------------- Prepare themes for outcome plots -----------------------

death_theme <- function(plot, ylim = c(0.45,3.1)){
   plot +
      labs(title = "All-cause mortality",
           y = "Adjusted hazard ratio",
           x = expression("Glomerular filtration rate, mL/min/1.73m"^2))  +
      scale_x_continuous(breaks = c(15, 30, 45, 60, 75, 90, 120), limits = c(15,120), minor_breaks = c(75, 105)) +
      scale_linewidth_manual(values = c(0.5, 1)) +  guides(linewidth = "none") +
      ylim(ylim) +
      theme_classic() +
      theme(plot.title = element_text(size = 10), aspect.ratio = 0.8, , axis.title = element_text(size = 9))
}

KFRT_theme <- function(plot, cutoff, breaks = c(0.01, 0.1, 1, 10, 100, 1000)){

   plot$data <- plot$data |>
      mutate(lower = if_else(lower < cutoff, cutoff, lower))

   plot +
   labs(title = "Kidney failure with replacement \ntherapy",
        y = expression("Adjusted hazard ratio"),
        x = expression("Glomerular filtration rate, mL/min/1.73m"^2))  +
   scale_x_continuous(breaks = c(15, 30, 45, 60, 75, 90, 120), limits = c(15,120), minor_breaks = c(75, 105)) +
   scale_linewidth_manual(values = c(0.5, 1)) +  guides(linewidth = "none") +
   scale_y_log10(breaks = breaks,
                 labels = breaks) +
   theme_classic() +
   theme(plot.title = element_text(size = 10), aspect.ratio = 0.8, , axis.title = element_text(size = 9))
}

