#------------------------- Prepare layout for HR tables ------------------------

ref90 <- c("All-cause Mortality", "KFRT", "AKI", "Heart Failure", "MACE")

prepare_table <- function(.table) {
  .table |>
  relocate(MACE, .after = `Heart Failure`) |>
  rename_with(~ paste0("All-cause Mortality"), starts_with("All-cause")) |>
  mutate(GFR = factor(GFR, levels = c(15, 30, 45, 60, 75, 90, 120))) |>
  arrange(GFR) |>
  mutate(predictor = str_replace_all(predictor, "\\[", "<sub>"),
  predictor = str_replace_all(predictor, "\\]", "</sub>"),
  across(ref90, ~ if_else(GFR == 90, "ref.", .x)))
}



make_gt_results <- function(.table) {
   .table |>
      gt(groupname_col = "predictor",
         row_group_as_column = TRUE,
         process_md = TRUE) |>
      tab_options(table.font.size = 11) %>%
      opt_footnote_marks(marks = "extended") |>
      tab_style(style = cell_text(v_align = "middle", align = "center"), # center the vertical alignment
                locations = list(cells_body(), cells_column_labels())) |>
      tab_footnote(footnote = md("Glomerular filtration rate, ml/min/1.73m<sup>2</sup>"),
                   locations = cells_column_labels(columns = "GFR")) |>
      tab_footnote(footnote = md("Adjusted hazard ratio (95% confidence interval), with reference value 90 ml/min/1.73m<sup>2</sup>"),
                   locations = cells_column_labels(columns = ref90)) |>
      tab_footnote(footnote = md("AKI = Acute kidney injury;
   GFR = glomerular filtration rate;
   eGFR<sub>cr</sub> = estimated glomerular filtration rate based on creatinine;
   eGFR<sub>cys</sub> = estimated glomerular filtration rate based on cystatin C;
   eGFR<sub>cr-cys</sub> = estimated glomerular filtration rate based on creatinine and cystatin C;
   mGFR = measured glomerular filtration rate;
   KFRT = Kidney failure with replacement therapy;
   MACE = Major adverse cardiovascular outcomes;
   ref. = reference")) |>
      gt::opt_footnote_marks(marks = "extended")
}

table_to_docx <- function(.table, filename_wo_extension) {
   .table |>
   gtsave(filename = glue::glue("{filename_wo_extension}.docx"),
       path = here::here("output","manuscript"))
}

