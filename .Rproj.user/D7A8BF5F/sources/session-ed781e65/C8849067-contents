## MAIN ANALYSIS ---------------------------------------------------------------

### ---- Prepare tidy labels ----
oer_tbl <- results %>%
  rename(equation = equations) %>%
  select(equation, horizons, starts_with("O_E_")) %>%
  filter(!str_detect(equation, "revised")) %>%
  mutate(
    biomarker = case_when(
      str_detect(equation, "cr_cys") ~ "Creatinine + Cystatin C",
      str_detect(equation, "cys") ~ "Cystatin C",
      str_detect(equation, "cr") ~ "Creatinine"
    ),
    biomarker = factor(
      biomarker,
      levels = c("Creatinine", "Cystatin C", "Creatinine + Cystatin C"),
      labels = c("bold(eGFR[cr])", "bold(eGFR[cys])", "bold(eGFR[cr~'-'~cys])")
    ),
    equation = case_when(
      str_detect(equation, "ekfc") ~ "EKFC",
      str_detect(equation, "ckd") ~ "CKD-EPI",
    )
    # equation = factor(
    #   equation,
    #   levels = equations[!str_detect(equations, "revised")],
    #   labels = c("CKD-EPI[cr] 2009", "CKD-EPI[cys] 2012", "CKD-EPI[cr-cys] 2012",
    #              "EKFC[cr]", "EKFC[cys]", "EKFC[cr-cys]")
    # )
  )

### ---- Plot ----
# Custom labeller for the rows (horizons)
horizon_labeller <- function(x) paste0(x, "-year KFRE")

# Custom labeller for the columns (biomarkers, using expressions)
biomarker_labeller <- label_parsed

arrow_df <- data.frame(
  xstart = c(1, 1),
  xend = c(0.45, 1.55),
  y = rep(0.6, 2), # relative to the y-axis; adjust as needed
  label = c("Risk \noverestimated", "Risk \nunderestimated"),
  xtext = c(0.7, 1.3)
)

# oer_tbl$y_pos <- as.numeric(factor(oer_tbl$equation, levels = rev(unique(oer_tbl$equation))))
oer_tbl$y_pos <- c(rep(1.5, 6), rep(1, 6))


oer_plots <- ggplot(
  oer_tbl,
  aes(y = y_pos, x = O_E_Ratio, xmin = O_E_lower, xmax = O_E_upper)
) +
  geom_vline(xintercept = 1, linetype = "dashed", color = "gray40") +
  geom_errorbarh(height = 0.1, color = "#0072B2", linewidth = 0.5) +
  geom_point(shape = 21, size = 1.5, fill = "#0072B2", color = "white") +

  # Arrows & annotations
  # Arrows
  geom_segment(
    data = arrow_df,
    aes(x = xstart, xend = xend, y = y, yend = y),
    arrow = arrow(length = unit(0.15, "cm")),
    color = "gray40",
    inherit.aes = FALSE
  ) +
  geom_text(
    data = arrow_df,
    aes(x = xtext, y = y, label = label),
    color = "gray40",
    size = 2,
    inherit.aes = FALSE
  ) +

  facet_grid(
    horizons ~ biomarker,
    labeller = labeller(
      horizons = horizon_labeller, # plain text for rows
      biomarker = biomarker_labeller # parse expressions for columns
    ),
    switch = "y"
  ) +
  scale_x_log10(
    limits = c(0.4, 1.6),
    breaks = c(0.4, 0.6, 0.8, 1.2, 1.6),
    labels = scales::label_number(accuracy = 0.1)
  ) +
  scale_y_continuous(
    limits = c(0.4, 1.75),
    breaks = unique(oer_tbl$y_pos),
    labels = rev(unique(oer_tbl$equation))
  ) +
  labs(
    x = "Observed / Expected ratio",
    y = NULL
  ) +
  theme_bw() +
  theme(
    strip.placement = "outside",

    # clean black text on white facet strips
    strip.background = element_rect(fill = "white", color = NA),
    strip.text.x = element_text(size = 9, color = "black"),
    strip.text.y.left = element_text(size = 9, color = "black", face = "bold"),

    axis.text.y = element_text(face = "bold", size = 9),
    axis.text.x = element_text(size = 8),
    panel.grid.minor = element_blank(),
    panel.grid.major.x = element_blank(), # remove vertical lines
    panel.grid.major.y = element_line(color = "gray80", linewidth = 0.5), # keep horizontal lines
  )

save_for_manuscript(
  "oe_ratios_plot",
  oer_plots,
  height = 164 * 0.5,
  width = 164
)


