load(file = here("Data", "analyses", "delta_brier.rda"))
delta_brier

## MAIN ANALYSIS ---------------------------------------------------------------

# Rows = markers
# Groups of rows = horizon
# Columns: Brier, scaled brier, delta
# Group of columns : CKD-EPI, EKFC

# Make sure model is treated as factor with a clear label
delta_brier_tbl <- delta_brier %>%
  filter(stringr::str_detect(model, "ekfc")) %>%
  mutate(
    # Label biomarker type
    biomarker = case_when(
      grepl("cr_cys", model) ~ "Creatinine + Cystatin C",
      grepl("cys", model) ~ "Cystatin C",
      grepl("cr", model) ~ "Creatinine"
    ),
    # Order for display
    biomarker = factor(
      biomarker,
      levels = c("Creatinine + Cystatin C", "Cystatin C", "Creatinine"),
      labels = c("bold(eGFR[cr~'-'~cys])", "bold(eGFR[cys])", "bold(eGFR[cr])")
    )
  )

# Create the forest plot
delta_brier_plot <- ggplot(
  delta_brier_tbl,
  aes(x = delta.Brier, y = biomarker, xmin = lower, xmax = upper)
) +
  geom_vline(xintercept = 0, linetype = "dashed", color = "gray40") +
  geom_errorbarh(height = 0.15, linewidth = 0.8, color = "#0072B2") +
  geom_point(size = 2, color = "white", shape = 21, fill = "#0072B2") +
  facet_wrap(
    ~horizon,
    ncol = 1,
    labeller = labeller(horizon = ~ paste0(.x, "-year KFRE"))
  ) +
  # scale_color_manual(values = c("EKFC" = "#0072B2", "CKD-EPI" = "#009E73")) +
  scale_x_continuous(
    limits = c(-0.0045, 0.0045),
    breaks = seq(-0.004, 0.004, by = 0.002),
    labels = scales::label_number(accuracy = 0.002)
  ) +
  scale_y_discrete(
    expand = expansion(add = c(0.7, 0.3)),
    labels = scales::label_parse(),
  ) +
  labs(
    x = expression(Delta ~ Brier ~ Score ~ "(EKFC - CKD-EPI)"),
    y = NULL
  ) +
  # Arrows and text annotations
  annotate(
    "segment",
    x = 0,
    xend = -0.0025,
    y = 0.5,
    yend = 0.5,
    arrow = arrow(length = unit(0.1, "inches")),
    color = "gray30"
  ) +
  annotate(
    "text",
    x = -0.00175,
    y = 0.675,
    label = "EKFC better",
    hjust = 0,
    color = "gray30",
    size = 3.2
  ) +
  annotate(
    "segment",
    x = 0,
    xend = 0.0025,
    y = 0.5,
    yend = 0.5,
    arrow = arrow(length = unit(0.1, "inches")),
    color = "gray30"
  ) +
  annotate(
    "text",
    x = 0.00213,
    y = 0.675,
    label = "CKD-EPI better",
    hjust = 1,
    color = "gray30",
    size = 3.2
  ) +
  theme_bw() +
  theme(
    legend.position = "bottom",
    axis.text.y = element_text(face = "bold"),
    axis.text.x = element_text(size = 9),
    strip.text = element_text(size = 9, face = "bold"),
