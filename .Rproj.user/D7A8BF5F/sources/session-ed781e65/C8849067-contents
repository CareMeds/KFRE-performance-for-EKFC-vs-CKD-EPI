  ) + # uniform spacing
  ggplot2::geom_vline(
    xintercept = 0, # reference line at zero difference
    linetype = "dashed",
    color = "black"
  ) +
  ggplot2::labs(
    title = "5-year KFRE risk difference between CKD-EPI \n2009-2012 and EKFC equations",
    x = "Risk difference (Risk EKFC - Risk CKD-EPI)",
    y = "Biomarker"
  ) +
  ggplot2::theme_minimal(base_size = 12) +
  ggplot2::theme(
    panel.spacing = ggplot2::unit(0.5, "lines"),
    axis.text.y = ggplot2::element_text(size = 10),
    legend.position = "none"
  )

## combine plots ---------------------------------------------------------------------

combined_plot_diff <- (plot_KFRE_diff_2y + plot_KFRE_diff_5y) +
